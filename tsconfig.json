{
  "compilerOptions": {
    "moduleResolution": "node",
    "types": ["cypress", "cypress-map", "node", "cypress-data-session"],
    "target": "es2016",
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "src",
    "paths": {
      "@support/*": ["../cypress/support/*"],
      "@fixtures/*": ["../cypress/fixtures/*"]
    }
  },
  "include": [
    "cypress/support/component.tsx",
    "cypress/support/**/*.ts",
    "cypress/e2e/**/*.js",
    "cypress/e2e/**/*.ts",
    "src/**/*.cy.js",
    "cypress/e2e/from-lessons/lesson04-KEY-sort-by-price.cytjs"
  ]
}
